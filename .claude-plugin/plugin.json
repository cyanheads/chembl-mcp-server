{
  "name": "chembl-mcp-server",
  "version": "0.2.0",
  "description": "Link compounds to protein targets, rank bioactivity, and look up drug mechanisms and indications.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/chembl-mcp-server#readme",
  "repository": "https://github.com/cyanheads/chembl-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "chembl-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/chembl-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
